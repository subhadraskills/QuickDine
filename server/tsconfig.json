{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "rootDir": "./",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
  

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

   

  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules"]
}